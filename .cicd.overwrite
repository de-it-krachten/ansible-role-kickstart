---

# Generic
generic:
  role: ansible-role-kickstart
  role_short: kickstart
  role_description: |
    Create kickstart file for automatic installation of RedHat and derivatives
    Kickstart file can be plain or within an image like iso or floppy
  collections: []

# Supported platforms
platforms:
  debian11:
    supported: false
    ci: false
  debian12:
    supported: false
    ci: false
  debian13:
    supported: false
    ci: false
  ubuntu2204:
    supported: false
    ci: false
  ubuntu2404:
    supported: false
    ci: false
  fedora42:
    supported: false
    ci: false
  fedora43:
    supported: false
    ci: false

# Molecule
molecule:
  requirements:
    roles_extra: []
  prepare:
    vars:
      activate_epel: true
      install_python: true
      python38: false
      python39: true
      python311: true
  converge:
    vars:
      kickstart_distros:
        - { name: Rocky, version: 8, mode: iso }
        - { name: Rocky, version: 9, mode: iso }
        - { name: OracleLinux, version: 8, mode: iso }
        - { name: OracleLinux, version: 9, mode: iso }
        - { name: Rocky, version: 8, mode: fdd }
        - { name: Rocky, version: 9, mode: fdd }
        - { name: OracleLinux, version: 8, mode: fdd }
        - { name: OracleLinux, version: 9, mode: fdd }

# CI templates
ci_templates:
  converge.yml:
    force: false

